import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
      Scanner k=new Scanner(System.in);
      int last,rev=0;
      System.out.println("enter the number to be reveresed");
      int m=k.nextInt();
      int n=m;
      System.out.println("the number before reversal"+n);
      while(n>0){
        last=n%10;
        rev=rev*10+last;
        n=n/10;}
      System.out.println("the reversed number is:"+rev);
      if(m==rev){
        System.out.println("the entered number is a palindrome");
      }else{
        System.out.println("the entered number is not palindrome");
      }
      }
    }
