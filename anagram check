import java.util.Arrays;
import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
     Scanner k=new Scanner (System.in);
     System.out.println("enter the 1st string:");
     String s1=k.nextLine();
     System.out.println("enter the 2nd string:");
     String s2=k.nextLine();
     char[] a=s1.toLowerCase().toCharArray();
     char[] b=s2.toLowerCase().toCharArray();
     if(a.length!=b.length){System.out.println("the entered strings are not anagram");}
     Arrays.sort(a);
     Arrays.sort(b);
     if(Arrays.equals(a,b)){System.out.println("it is a anagram");}
     else{System.out.println("is not a anagram");}
     }
}
