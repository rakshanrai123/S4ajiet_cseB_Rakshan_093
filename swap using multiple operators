import java.util.*;

public class Main {
    public static void main(String[] args) {
      int a=5,b=6;
      System.out.println("a:"+a);
      System.out.println("b:"+b);
      a+=b;
      b=a-b;
      a-=b;
      System.out.println("variables after swapping:");
      System.out.println("a:"+a);
      System.out.println("b:"+b);
      
    }
}
