import java.util.*;

public class Main {
    public static void main(String[] args) {
      int a=5,b=6;
      System.out.println("a:"+a);
      System.out.println("b:"+b);
      int temp=a;
      a=b;
      b=temp;
      System.out.println("variables after swapping:");
      System.out.println("a:"+a);
      System.out.println("b:"+b);
    }
}
